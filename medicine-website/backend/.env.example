# Copy this file to .env and fill in real values. Do NOT commit .env.

# Set to "production" on your host. Enables CORS fail-closed + request logging.
NODE_ENV=production

# MongoDB connection string (e.g. from MongoDB Atlas)
MONGO_URI=

# Port the API listens on (most hosts set this automatically)
PORT=5000

# Long random string used to sign JWTs.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Gmail account + app password used to send OTP + order emails.
# Create an App Password at https://myaccount.google.com/apppasswords
EMAIL_USER=
APP_PASSWORD=

# Where new-order / cancellation notifications are sent.
# Defaults to EMAIL_USER if left blank.
ADMIN_EMAIL=

# Allowed frontend origin(s) for CORS — your deployed frontend URL(s),
# comma-separated. e.g. https://medicare.vercel.app
#
# ⚠️ REQUIRED IN PRODUCTION. With NODE_ENV=production, CORS fails CLOSED:
#    if CLIENT_URL is blank, EVERY non-localhost request is rejected and the
#    whole frontend breaks. Always set this to your real frontend URL on deploy.
CLIENT_URL=http://localhost:5173
