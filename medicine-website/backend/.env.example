# Copy this file to .env and fill in real values. Do NOT commit .env.

# MongoDB connection string (e.g. from MongoDB Atlas)
MONGO_URI=

# Port the API listens on
PORT=5000

# Long random string used to sign JWTs.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Gmail account + app password used to send OTP + order emails.
# Create an App Password at https://myaccount.google.com/apppasswords
EMAIL_USER=
APP_PASSWORD=

# Where new-order / cancellation notifications are sent.
# Defaults to EMAIL_USER if left blank.
ADMIN_EMAIL=

# Allowed frontend origin for CORS (your deployed frontend URL in production).
# IMPORTANT: always set this in production — if blank, CORS allows all origins.
CLIENT_URL=http://localhost:5173
